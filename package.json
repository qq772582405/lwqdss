        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.1",
        "esbuild": "^0.28.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "jsdom": "^29.0.2",
